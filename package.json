{
    "name": "ai-history-show",
    "version": "0.1.0",
    "private": true,
    "description": "Interactive AI history exhibition screen application.",
    "scripts": {
        "start": "npm run start:static",
        "start:static": "node scripts/static-server.js",
        "start:admin": "node manage/server.js",
        "start:demo": "node scripts/static-server.js --host 127.0.0.1 --port 8000",
        "generate": "node scripts/generate-archive-data.js",
        "generate:archive": "node scripts/generate-archive-data.js",
        "generate:event-pack": "node scripts/generate-event-markdown-pack.js",
        "generate:event-pack:images": "node scripts/generate-event-markdown-pack.js --download-remote",
        "build:static": "node scripts/build-static-site.js",
        "lint": "eslint .",
        "format": "prettier --write \"manage/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "format:check": "prettier --check \"manage/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "test": "node scripts/test-layout-router.js && node scripts/test-swipe-navigation.js && node scripts/test-storyline-routing.js && node scripts/test-mobile-responsive.js && node scripts/test-analytics.js && node scripts/test-archive-authority.js && node scripts/test-content-tooling.js && node scripts/audit-event-figures.js --check",
        "quality": "npm run lint && npm run format:check && npm test",
        "validate:startup": "node scripts/validate-startup.js",
        "validate:event-pack": "node scripts/validate-event-markdown-pack.js",
        "validate:archive": "node scripts/validate-archive.js",
        "migrate:figure-avatars": "node scripts/migrate-archive-figure-avatars.js",
        "report:assets": "node scripts/report-assets-usage.js",
        "validate:ai100-context": "node scripts/validate-ai100-context.js",
        "validate:ai100-quizzes": "node scripts/validate-ai100-quizzes-grounded.js",
        "audit:ai100-accuracy": "node scripts/audit-ai100-accuracy.js",
        "audit:figures": "node scripts/audit-event-figures.js",
        "audit:figures:check": "node scripts/audit-event-figures.js --check",
        "audit:svg-explainers": "node scripts/audit-svg-explainers.js",
        "audit:svg-geometry": "node scripts/run-svg-geometry-audit.js",
        "validate:deployment": "npm run validate:archive && npm run generate && npm run build:static && npm test && npm run validate:startup"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0"
    },
    "engines": {
        "node": ">=22"
    }
}
