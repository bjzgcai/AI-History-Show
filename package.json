{
    "name": "ai-history-show",
    "version": "0.1.0",
    "private": true,
    "description": "Interactive AI history exhibition screen application.",
    "scripts": {
        "start": "npm run start:static",
        "start:static": "node scripts/static-server.js",
        "start:admin": "node manage/server.js",
        "start:demo": "node scripts/static-server.js --host 127.0.0.1 --port 8000",
        "generate": "node scripts/generate-archive-data.js",
        "generate:archive": "node scripts/generate-archive-data.js",
        "generate:legacy": "node manage/generate.js",
        "generate:parity": "node scripts/generate-archive-parity.js",
        "diff:parity": "node scripts/diff-archive-parity.js",
        "review:parity": "node scripts/review-archive-parity.js",
        "serve:parity": "node scripts/archive-parity-server.js",
        "lint": "eslint .",
        "format": "prettier --write \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "format:check": "prettier --check \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "test": "node scripts/test-layout-router.js && node scripts/test-swipe-navigation.js && node scripts/test-storyline-routing.js && node scripts/test-mobile-responsive.js && node scripts/test-archive-authority.js",
        "quality": "npm run lint && npm run format:check && npm test",
        "validate:startup": "node scripts/validate-startup.js",
        "validate:archive": "node scripts/validate-archive.js",
        "build:archive": "node scripts/build-archive.js",
        "diff:archive": "node scripts/diff-archive-build.js",
        "review:archive": "node scripts/generate-archive-review.js",
        "preview:archive-data": "node scripts/generate-archive-preview-data.js",
        "generate:archive-native-preview": "node scripts/generate-archive-native-data.js",
        "migrate:archive-presentation": "node scripts/migrate-archive-presentation.js",
        "diff:archive-preview": "node scripts/diff-archive-preview-data.js",
        "diff:archive-native": "node scripts/diff-archive-native-data.js",
        "diff:archive-legacy-main": "node scripts/diff-archive-legacy-main.js",
        "report:archive-native-fields": "node scripts/report-archive-native-field-coverage.js",
        "audit:legacy-data": "node scripts/audit-legacy-data.js",
        "migrate:ai100-batch": "node scripts/migrate-ai100-batch.js",
        "migrate:archive": "node scripts/migrate-archive-events.js",
        "map:archive-fusions": "node scripts/map-archive-fusions.js",
        "report:assets": "node scripts/report-assets-usage.js",
        "validate:ai100-context": "node scripts/validate-ai100-context.js",
        "validate:ai100-quizzes": "node scripts/validate-ai100-quizzes-grounded.js",
        "audit:ai100-accuracy": "node scripts/audit-ai100-accuracy.js",
        "validate:deployment": "npm run validate:archive && npm run generate && npm test && npm run validate:startup"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0"
    },
    "engines": {
        "node": ">=22"
    }
}
