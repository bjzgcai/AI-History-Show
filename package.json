{
    "name": "ai-history-show",
    "version": "0.1.0",
    "private": true,
    "description": "Interactive AI history exhibition screen application.",
    "scripts": {
        "start": "npm run start:static",
        "start:static": "node scripts/static-server.js",
        "start:admin": "node manage/server.js",
        "start:demo": "node scripts/static-server.js --host 127.0.0.1 --port 8000",
        "generate": "node manage/generate.js",
        "lint": "eslint .",
        "format": "prettier --write \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "format:check": "prettier --check \"shared/**/*.js\" \"scripts/**/*.{js,mjs}\" \".github/**/*.yml\" \"*.yml\" \"*.json\" \"eslint.config.js\"",
        "test": "node scripts/test-layout-router.js && node scripts/test-swipe-navigation.js && node scripts/test-mobile-responsive.js",
        "quality": "npm run lint && npm run format:check && npm test",
        "validate:startup": "node scripts/validate-startup.js",
        "validate:ai100-context": "node scripts/validate-ai100-context.js",
        "validate:ai100-quizzes": "node scripts/validate-ai100-quizzes-grounded.js",
        "audit:ai100-accuracy": "node scripts/audit-ai100-accuracy.js",
        "validate:deployment": "npm run generate && npm test && npm run validate:startup"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0"
    },
    "engines": {
        "node": ">=22"
    }
}
