{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.schema.json",
  "title": "Archive sources",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "type",
      "label",
      "title",
      "purpose",
      "reliability"
    ],
    "properties": {
      "id": {
        "$ref": "shared.schema.json#/$defs/archiveId"
      },
      "type": {
        "type": "string",
        "enum": [
          "internal-record",
          "paper",
          "paper-page",
          "paper-file",
          "paper-index",
          "book",
          "book-page",
          "book-file",
          "book-index",
          "documentation",
          "code",
          "project-page",
          "official-page",
          "personal-page",
          "profile",
          "archive",
          "article",
          "news",
          "report",
          "encyclopedia-entry",
          "image-source",
          "dataset",
          "statement",
          "thesis"
        ]
      },
      "label": {
        "$ref": "shared.schema.json#/$defs/localizedText"
      },
      "title": {
        "$ref": "shared.schema.json#/$defs/localizedText"
      },
      "authors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "year": {
        "oneOf": [
          {
            "type": "integer"
          },
          {
            "type": "string"
          }
        ]
      },
      "url": {
        "type": "string"
      },
      "doi": {
        "type": "string"
      },
      "archiveUrl": {
        "type": "string"
      },
      "language": {
        "type": "string"
      },
      "purpose": {
        "type": "string",
        "enum": [
          "core-evidence",
          "precursor",
          "follow-up",
          "alternate-access",
          "background",
          "historical-context",
          "biography",
          "image-provenance",
          "implementation",
          "dataset-access",
          "contemporary-reporting",
          "official-statement",
          "reporting",
          "bibliographic-verification",
          "migration-only"
        ]
      },
      "reliability": {
        "type": "string",
        "enum": [
          "primary",
          "secondary",
          "tertiary",
          "reference-only"
        ]
      },
      "notes": {
        "$ref": "shared.schema.json#/$defs/optionalLocalizedText"
      },
      "review": {
        "$ref": "shared.schema.json#/$defs/reviewState"
      }
    },
    "anyOf": [
      {
        "required": [
          "url"
        ]
      },
      {
        "required": [
          "doi"
        ]
      },
      {
        "required": [
          "archiveUrl"
        ]
      }
    ],
    "additionalProperties": true
  }
}
